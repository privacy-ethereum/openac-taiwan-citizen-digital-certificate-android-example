    <!-- Learn More Sheet -->
    <string name="intro_learn_shared">What information is shared</string>
    <string name="progress_learn_tech">Learn how this works</string>
    <string name="learn_more_nav_title">How this technology protects your data</string>
    <string name="learn_more_body">Traditional identity checks may ask you to share full credential data with a website. This flow is different: your browser or device prepares a verifiable result, and the website only receives what it needs for this verification.</string>
    <string name="learn_more_s1_title">Only the necessary result</string>
    <string name="learn_more_s1_body">The website usually only needs to know whether you meet the requirement, not your full identity details.</string>
    <string name="learn_more_s2_title">No full credential sharing</string>
    <string name="learn_more_s2_body">Your credential is used to prepare the verification result, but the website does not need to receive the full certificate contents.</string>
    <string name="learn_more_s3_title">Privacy-preserving technology</string>
    <string name="learn_more_s3_body">This flow uses OpenAC and zero-knowledge technology to confirm eligibility while reducing unnecessary data disclosure.</string>
